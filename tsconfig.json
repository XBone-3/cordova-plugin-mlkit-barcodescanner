{
  "include": [
    "./**/.eslintrc.js",
    "./rollup.config.js",
    "./src-typescript/**/*.ts",
    "./types/**/*.ts"
  ],
  "exclude": ["./test/"],
  "compilerOptions": {
    "target": "ES2019",
    "moduleResolution": "node",
    "lib": ["ES2019", "DOM"],
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "module": "ES2015",
    "outDir": "www",
    "skipLibCheck": true,
    "types": ["@types/cordova", "@types/node"]
  }
}
